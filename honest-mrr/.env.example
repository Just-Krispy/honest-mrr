# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Stripe Connect (for OAuth)
STRIPE_CLIENT_ID=ca_your_client_id_here

# Stripe Product IDs (create in Stripe Dashboard)
STRIPE_MONTHLY_PRICE_ID=price_your_monthly_price_id
STRIPE_ANNUAL_PRICE_ID=price_your_annual_price_id

# Security (generate secure random keys)
ENCRYPTION_KEY=your_32_byte_hex_key_here  # Generate: openssl rand -hex 32
OAUTH_STATE_SECRET=your_random_secret_here
VERIFICATION_SECRET=your_verification_secret_here

# PostHog (optional, for analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Resend (optional, for email)
RESEND_API_KEY=re_your_resend_api_key_here

# App URL (for webhooks, emails, OAuth redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000
